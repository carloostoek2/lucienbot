```python
async def check_and_expire_subscriptions(self) -> int:
    """
    Verifica suscripciones expiradas y las marca como inactivas.
    Retorna cantidad de suscripciones expiradas.
    """
    from datetime import datetime
    from sqlalchemy import select, update

    now = datetime.utcnow()

    # Buscar suscripciones activas que ya expiraron
    result = await self.db.execute(
        select(Subscription)
        .where(Subscription.is_active == True)
        .where(Subscription.expires_at < now)
    )
    expired = result.scalars().all()

    # Marcar como inactivas
    for sub in expired:
        sub.is_active = False
        # Opcional: Remover del canal VIP
        # await self.remove_user_from_vip_channel(sub.user_id)

    if expired:
        await self.db.commit()

    return len(expired)
```

